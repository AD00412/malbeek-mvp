# ملبّيك — إعداد Apache على استضافة cPanel (Namecheap Stellar)
# تطبيقٌ أحاديّ الصفحة (React/Vite): كلّ المسارات تُخدَم من index.html.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # فرض HTTPS (شهادة PositiveSSL مفعّلة) — يحوّل http إلى https
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

  # توحيد www → الجذر (اختياريّ، يمنع تكرار المحتوى)
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

  # توجيه SPA: أيّ مسارٍ ليس ملفًّا ولا مجلّدًا حقيقيًّا → index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

# ذاكرةُ تخزينٍ طويلةٌ للأصول المبصومة (hashed) — التحديث فوريٌّ مع كلّ إصدار
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|svg|png|jpg|jpeg|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # لا تُخزَّن صفحة الدخول نفسها — ليصل المستخدم لأحدث إصدارٍ دائمًا
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# ضغطٌ نصّيّ (أسرع تحميلًا)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
